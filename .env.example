# ─── Core ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/signalscout
SYNC_DATABASE_URL=postgresql://postgres:password@localhost:5432/signalscout
REDIS_URL=redis://localhost:6379/0

# ─── HuggingFace ─────────────────────────────────────────────────────────────
HF_TOKEN=hf_YOUR_TOKEN_HERE
HF_EMBEDDING_MODEL=BAAI/bge-m3
HF_RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
HF_SENTIMENT_MODEL=ProsusAI/finbert
HF_SUMMARIZATION_MODEL=facebook/bart-large-cnn
HF_ZERO_SHOT_MODEL=facebook/bart-large-mnli
HF_NLI_MODEL=cross-encoder/nli-deberta-v3-base
HF_ASR_MODEL=openai/whisper-large-v3
HF_VLM_MODEL=HuggingFaceM4/idefics3-8b-llama3

# ─── Supabase (pgvector cloud) ─────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_DB_URL=postgresql+asyncpg://postgres:password@db.YOUR_PROJECT.supabase.co:5432/postgres

# ─── External APIs ─────────────────────────────────────────────────────────
NEWS_API_KEY=your_newsapi_key_here         # → newsapi.org (free tier)
OPENAI_API_KEY=                            # optional — fallback VLM

# ─── LangSmith ─────────────────────────────────────────────────────────────
LANGSMITH_API_KEY=your_langsmith_key_here  # → smith.langchain.com (free)
LANGSMITH_PROJECT=signalscout
LANGSMITH_TRACING=false                    # set true once key is added

# ─── App Settings ─────────────────────────────────────────────────────────
APP_ENV=development                        # development | production
LOG_LEVEL=INFO
EMBEDDING_BATCH_SIZE=32
CHUNK_SIZE=512
CHUNK_OVERLAP=64
RETRIEVAL_TOP_K=20
RERANKER_TOP_K=5
CRITIQUE_SCORE_THRESHOLD=0.70
MAX_SELF_CORRECTION_LOOPS=2

# ─── Finance ──────────────────────────────────────────────────────────────
WATCHLIST_TICKERS=AAPL,MSFT,GOOGL,AMZN,NVDA,TSLA,META,JPM,GS,BRK-B
